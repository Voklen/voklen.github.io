---
import '../../styles/global.css'
import Navbar from '../../components/Navbar.astro'
import dialyDiaryIcon from '../../assets/images/projects/daily-diary/icon.png'
import dailyDiaryShakespeare from '../../assets/images/projects/daily-diary/phone-screenshots/shakespeares-diary.png'
import dailyDiarySettings from '../../assets/images/projects/daily-diary/phone-screenshots/settings.png'
import mitrella from '../../assets/images/projects/mitrella/mitrella.png'
import pythonQuine from '../../assets/images/projects/python-quine/source.png'
import moleculeSimStart from '../../assets/images/projects/covalent-molecule-simulation/sim-start.png'
import moleculeSimEnd from '../../assets/images/projects/covalent-molecule-simulation/sim-end.png'
import bearings from '../../assets/images/projects/bearings/source.png'
import haggisInterpreter from '../../assets/images/projects/haggis-interpreter/haggis-example.png'
---

<html lang="en">
	<head>
		<title>Alex Gorichev - Projects</title>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<style>
			#projects-grid {
				margin-right: 50px;
				margin-top: 12vh;
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
				gap: 8px;
			}

			.card {
				height: 350px;
				display: grid;
				grid-template-rows: 4fr 1fr 3fr;
				padding: 10px;
				border: solid 1px rgba(133, 159, 202, 0.2);
				border: solid 1px #334;
				border-radius: 10px;
			}

			.card > figure {
				min-width: 0;
				min-height: 0;
				display: flex;
				justify-content: center;
				align-items: center;
				gap: 2px;
			}

			.card > figure img {
				max-height: 100%;

				min-width: 0;
				min-height: 0;
			}

			.card > a {
				font-size: 1.5rem;
				font-weight: 700;
				font-style: normal;
				white-space: normal;
			}

			.card > p {
				margin: auto;
			}
		</style>
	</head>

	<body>
		<main>
			<div id="projects-grid">
				<div class="card">
					<figure>
						<img
							src={dialyDiaryIcon.src}
							alt="Icon of an open book and a fountain pen"
						/>
						<img
							src={dailyDiaryShakespeare.src}
							alt="Screenshot of the Daily Diary mobile app open on one of Shakespeare's diary entries."
						/>
						<img
							src={dailyDiarySettings.src}
							alt="Screenshot of the settings page on Daily Diary"
						/>
					</figure>
					<a href="https://github.com/Voklen/Daily-Diary">Daily Diary</a>
					<p>
						A diary app for android that has one entry per day that is saved as
						a plaintext file
					</p>
				</div>
				<div class="card">
					<figure>
						<img src={mitrella.src} alt="Screenshot of a graphing calculator app" />
					</figure>
					<a href="https://github.com/Voklen/Mitrella">Mitrella</a>
					<p>
						A graphing calculator, inspired by desmos but using my own
						stack-based mathematical notation.
					</p>
				</div>
				<div class="card">
					<figure>
						<img src={pythonQuine.src} alt="The Python source code that prints itself out"/>
					</figure>
					<a href="https://github.com/Voklen/Output-Source">Python Quine</a>
					<p>A Python program that prints out it's own source code.</p>
				</div>
				<div class="card">
					<figure>
						<img src={moleculeSimStart.src} alt="Randomly spread out 2D molecules at the start of the simulation"/>
						<img src={moleculeSimEnd.src} alt="2D molecules in long chains at the end of the simulation"/>
					</figure>
					<a href="https://github.com/Voklen/Covalent-Molecule-Simulation"
						>Covalent Bond Simulation</a
					>
					<p>
						A visual simulation of PD-PD forces made with the
						<a href="https://godotengine.org/">Godot game engine</a>.
					</p>
				</div>
				<div class="card">
					<figure>
						<img src={bearings.src} alt="Code sample from the bearings program written in Uiua"/>
					</figure>
					<a href="https://github.com/Voklen/Bearings">Bearings</a>
					<p>
						A small program to calculate bearings written in
						<a href="https://www.uiua.org/">Uiua</a>.
					</p>
				</div>
				<div class="card">
					<figure>
						<img src={haggisInterpreter.src} alt="Some example Haggis code"/>
					</figure>
					<a href="https://github.com/Voklen/Haggis-Interpreter"
						>Haggis Interpreter</a
					>
					<p>
						A small interpreter for the SQA's (Scottish Qualifications
						Authority) programming language 'Haggis' writen in Rust.
					</p>
				</div>
			</div>
		</main>
		<Navbar />
	</body>
</html>
